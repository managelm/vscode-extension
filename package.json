{
  "name": "managelm",
  "displayName": "ManageLM",
  "description": "Manage Linux servers from VS Code Copilot Chat",
  "version": "1.0.1",
  "publisher": "managelm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/managelm/vscode-extension"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "keywords": [
    "managelm",
    "linux",
    "server",
    "management",
    "copilot",
    "devops"
  ],
  "extensionDependencies": [
    "github.copilot-chat"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "managelm.chat",
        "fullName": "ManageLM",
        "name": "managelm",
        "description": "Manage your Linux servers through natural language",
        "isSticky": true
      }
    ],
    "configuration": {
      "title": "ManageLM",
      "properties": {
        "managelm.portalUrl": {
          "type": "string",
          "default": "https://app.managelm.com",
          "description": "ManageLM portal URL"
        },
        "managelm.apiKey": {
          "type": "string",
          "default": "",
          "description": "ManageLM API key (from Portal > Settings > MCP & API)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
